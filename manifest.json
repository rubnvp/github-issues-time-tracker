{
  "manifest_version": 3,
  "name": "GitHub Issues Time Tracker",
  "version": "0.1.0",
  "description": "Track time spent on GitHub Issues directly from GitHub Projects",
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "src/storage.js",
        "src/timer.js",
        "src/injector.js",
        "src/observer.js",
        "src/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}